# Panel Event - Environment Configuration
# Copy this file to .env and adjust values

# API Configuration
PUBLIC_API_BASE_URL=http://localhost:3000/api
PUBLIC_EVENT_ID=evento-ef

# Auth (Basic Auth credentials)
PUBLIC_AUTH_USER=your_user
PUBLIC_AUTH_PASS=your_password

# Base path for deployment (must match svelte.config.js paths.base)
PUBLIC_BASE_PATH=/panel
